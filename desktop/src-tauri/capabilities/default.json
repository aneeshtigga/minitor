{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capabilities for the Minitor control panel",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        { "name": "binaries/minitor", "sidecar": true }
      ]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "brew", "cmd": "brew", "args": true },
        { "name": "bash", "cmd": "bash", "args": true },
        { "name": "open", "cmd": "open", "args": true },
        { "name": "pgrep", "cmd": "pgrep", "args": true }
      ]
    }
  ]
}
