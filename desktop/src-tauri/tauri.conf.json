{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Minitor",
  "version": "0.5.0",
  "identifier": "org.minitor.desktop",
  "build": {
    "frontendDist": "../src-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Minitor",
        "width": 520,
        "height": 720,
        "minWidth": 460,
        "minHeight": 600,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": ["binaries/minitor"],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
