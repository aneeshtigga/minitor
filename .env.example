# ---- minitor config ----
# Copy this file to ".env" and adjust as needed.

# Port the minitor service listens on (addon + UI + streaming all live here).
# NOTE: avoid 11470 AND 11471 — Stremio's own streaming server uses both.
PORT=11472

# Public base URL Stremio should use to reach this service.
# On the same machine, localhost is fine. If Stremio runs on another device
# (phone, TV) point this at your machine's LAN IP, e.g. http://192.168.1.50:11472
PUBLIC_URL=http://127.0.0.1:11472

# Interface to bind to. Default 127.0.0.1 keeps the addon (and the qBittorrent
# Web UI it proxies) off the LAN. To reach it from a phone/TV, set BIND_HOST to
# 0.0.0.0 AND point PUBLIC_URL at your LAN IP above — only on a trusted network.
BIND_HOST=127.0.0.1

# ---- Streaming mode (the "which version" switch) ----
#   direct : hand Stremio the torrent's infoHash and let ITS engine stream it.
#            Lightweight, no local download (like Torrentio). qBittorrent is NOT
#            required in this mode — only Jackett.
#   cache  : minitor adds the torrent to qBittorrent, downloads it to disk, and
#            range-streams the local file (permanent local copy, stream-while-
#            downloading). Requires qBittorrent configured below.
# The manifest id/name differ per mode, so you can run two instances (different
# PORT/PUBLIC_URL) and install BOTH in Stremio side-by-side.
STREAM_MODE=direct

# ---- qBittorrent Web API (only needed when STREAM_MODE=cache) ----
# Enable the Web UI in qBittorrent: Tools > Options > Web UI.
QBIT_URL=http://127.0.0.1:8080
QBIT_USER=admin
QBIT_PASS=adminadmin

# Where qBittorrent saves downloads. minitor reads files straight off disk
# for streaming, so this MUST match qBittorrent's "Default Save Path".
DOWNLOAD_DIR=/Users/aneeshtigga/Downloads/minitor

# Category applied to torrents minitor adds (keeps them separate in qBittorrent)
QBIT_CATEGORY=minitor

# ---- Jackett (Torznab aggregator, optional) ----
# When both are set, minitor also searches Jackett's "all indexers" endpoint —
# fuller release names and many more indexers than the built-in qBittorrent
# plugins. Install Jackett, add indexers in its UI (http://127.0.0.1:9117), and
# copy the API key (UI top-right). Leave blank to disable.
JACKETT_URL=http://127.0.0.1:9117
JACKETT_API_KEY=
